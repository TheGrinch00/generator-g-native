import React from "react";
import { View, Text, Pressable } from "react-native";
import { use<%= formName %> } from "./index.hooks";

type <%= formName %>Props = {}

export const <%= formName %> = ({}: <%= formName %>Props) => {
  const { form } = use<%= formName %>();

  return (
    <View className="p-4 gap-4">
      {/* Example: <form.AppField name="name" children={(field) => <field.FormTextField placeholder="Name" />} /> */}

      <Pressable
        className="bg-primary py-3 px-6 rounded-lg items-center"
        onPress={() => form.handleSubmit()}
      >
        <Text className="text-primary-foreground text-base font-semibold">Submit</Text>
      </Pressable>
    </View>
  );
};

<%= formName %>.displayName = "<%= formName %>";
