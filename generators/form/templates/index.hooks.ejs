import { useForm } from "@tanstack/react-form";
import { z } from "zod";

const schema = z.object({
  // name: z.string({ required_error: "Error message" })
});

export const use<%= formName %> = () => {
  const form = useForm({
    defaultValues: {
      // name: "",
    } as z.infer<typeof schema>,
    onSubmit: async ({ value }) => {},
    validators: {
      onSubmit: schema,
    },
  });

  return {
    form,
  };
};
